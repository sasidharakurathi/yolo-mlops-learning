# ===========================================================================
#  .gitignore for a YOLO + MLOps learning project (Python / PyTorch / ML)
# ===========================================================================

# --------------------------- Python ----------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --------------------- Virtual environments --------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.conda/
conda-env/

# ------------------------- Environments / secrets --------------------------
.env
.env.*
*.env
secrets.yaml
credentials.json
# ClearML / W&B / Comet / Neptune API keys & local config
clearml.conf
.clearml/
.netrc

# ------------------------ Jupyter / IPython --------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ============================ ML / YOLO ====================================

# --- Ultralytics / YOLO training outputs ---
runs/
runs_*/
wandb/
yolo*.pt          # auto-downloaded pretrained weights (ignore the big files)
*.pt
*.pth
*.onnx
*.engine          # TensorRT
*.mlmodel         # CoreML
*.tflite
*.pb
*.torchscript
*.bin
best.pt
last.pt
events.out.tfevents.*   # TensorBoard logs

# --- Experiment tracking local stores ---
mlruns/
mlartifacts/
.mlflow/
catboost_info/
lightning_logs/

# --- Datasets & large media (version these with DVC instead of Git) ---
datasets/
data/raw/
data/processed/
data/external/
*.zip
*.tar
*.tar.gz
*.7z
# Uncomment if you don't want ANY images/videos committed:
# *.jpg
# *.jpeg
# *.png
# *.mp4
# *.avi

# --- DVC (keep .dvc/config & *.dvc files; ignore the local cache) ---
/.dvc/cache
/.dvc/tmp
/.dvc/plots
.dvc/cache/
.dvc/tmp/

# ============================ Tooling ======================================

# --- Testing / coverage / linters ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.dmypy.json

# --- Docker ---
*.pid

# ============================ Editors / OS =================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
